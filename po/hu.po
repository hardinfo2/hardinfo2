msgstr "A CPU-t a SWAPGS utasítás által végzett spekulatív végrehajtás érinti"

#. !/bug:itlb_multihit
msgctxt "x86-flag"
msgid "CPU may incur MCE during certain page attribute changes"
msgstr ""
"A processzor bizonyos oldalattribútum-módosítások során MCE-t (Machine Check "
"Exception) okozhat"

#. !/bug:srbds
msgctxt "x86-flag"
msgid "CPU may leak RNG bits if not mitigated"
msgstr ""
"A processzor véletlenszám-generátorának bitei kiszivároghatnak, ha nem "
"alkalmaznak megfelelő intézkedéseket"

#. !/bug:mmio_stale_data
msgctxt "x86-flag"
msgid "CPU is affected by Proccesor MMIO Stale Data vulnerbilities"
msgstr ""
"A processzor érintett a Processzor MMIO-val kapcsolatos adatfrissítési "
"problémák által"

#. !/bug:mmio_unknown
msgctxt "x86-flag"
msgid "MMIO State Data status is unknown"
msgstr "Az MMIO állapotadatok állapota ismeretlen"

#. !/bug:retbleed
msgctxt "x86-flag"
msgid "CPU is affected by RETBleed"
msgstr "A CPU érintett a RETBleed sebezhetőség által"

#. !/bug:eibrs_pbrsb
msgctxt "x86-flag"
msgid "EIBRS is vulnerable to Post Barrier Address Predictions"
msgstr "Az EIBRS sebezhető a Barrier utáni címek előrejelzésével szemben"

#. !/bug:gds
msgctxt "x86-flag"
msgid "CPU is affected by Gather Data Sampling"
msgstr "A CPU-t befolyásolja az adatmintavételezés"

#. !/bug:srso
msgctxt "x86-flag"
msgid "AMD BTB untrain RETs"
msgstr "AMD: a BTB-táblázatban található RET-értékek törlése"

#. !/bug:bhi
msgctxt "x86-flag"
msgid "CPU is affected by Branch History Injection"
msgstr ""
"A CPU sérülékennyé válik a Branch History Injection támadásával szemben"

#. !/bug:ibpb_no_ret
msgctxt "x86-flag"
msgid "IBPB omits return target predictions"
msgstr "Az IBPB nem tesz közzé előrejelzéseket a várható hozamokról"

#. !/bug:spectre_v2_user
msgctxt "x86-flag"
msgid "CPU is affected by Spectre variant 2 attack between user processes"
msgstr ""
"A CPU érintett a Spectre típusú támadás 2-es változata által, amely a "
"felhasználói folyamatok között terjed"

#. !/bug:its
msgctxt "x86-flag"
msgid "CPU is affected by Indirect Target Selection"
msgstr "A CPU-t érinti az indirekt célpontválasztás"

#. !/bug:its_native_only
msgctxt "x86-flag"
msgid "CPU is affected by ITS, VMX is not affected"
msgstr "A CPU-t érinti az ITS, a VMX-et nem"

#. !/bug:tsa
msgctxt "x86-flag"
msgid "CPU is affected by Transient Scheduler Attacks"
msgstr "A processzor érintett a pillanatnyi ütemezőre irányuló támadásokban"

#. !/bug:vmscape
msgctxt "x86-flag"
msgid "CPU is affected by VMSCAPE attacks from guests"
msgstr "A CPU érintett a vendégrendszerekből érkező VMSCAPE-támadások által"

